---
import { navItems } from '../data/sections';
---

<nav class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between flex-wrap gap-4">
    <a href="/" class="text-xl font-bold tracking-tight text-[var(--color-text)] hover:text-[var(--color-accent)]">
      mypcrig
    </a>
    <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
      {navItems.map((s) => (
        <li>
          <a href={s.href} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)]">
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
