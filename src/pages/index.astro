---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const latestPosts = allPosts.slice(0, 6);

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);

const sections = [
  {
    href: '/ai-dev/',
    title: 'AI開発向け',
    headline: 'ローカルLLMが動くPC',
    description: 'VRAM別の動作モデル / 実機ベンチマーク / Claude Code 快適化',
  },
  {
    href: '/gaming/',
    title: 'ゲーミングPC',
    headline: 'FPS / MMO / 配信',
    description: '予算別ランキング / フレームレート実測 / 用途別構成',
  },
  {
    href: '/laptop/',
    title: 'ノートPC',
    headline: '軽量 / バッテリー / 性能',
    description: '学生・ビジネス・クリエイター向け選び方',
  },
  {
    href: '/mac/',
    title: 'Mac',
    headline: 'Apple Silicon',
    description: 'M3 / M4 シリーズ徹底比較 / Unified Memory の実力',
  },
  {
    href: '/desktop/',
    title: 'デスクトップ',
    headline: 'BTO / 自作',
    description: '拡張性と静音性のバランス / コスパ最強構成',
  },
  {
    href: '/parts/',
    title: 'パーツ単体',
    headline: 'GPU / CPU / メモリ',
    description: '単品レビュー / 世代比較 / アップグレード指南',
  },
];

const categoryLabels: Record<string, string> = {
  ranking: 'ランキング',
  review: 'レビュー',
  guide: 'ガイド',
  benchmark: 'ベンチマーク',
  comparison: '比較',
};

const sectionLabels: Record<string, string> = {
  laptop: 'ノートPC',
  gaming: 'ゲーミング',
  'ai-dev': 'AI開発',
  mac: 'Mac',
  desktop: 'デスクトップ',
  parts: 'パーツ',
  column: 'コラム',
};
---

<BaseLayout>
  <section class="py-12 md:py-20 text-center">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
      あなたに合うPCを<br class="md:hidden" />見つける
    </h1>
    <p class="text-lg md:text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto mb-8">
      用途・予算・制約から、あなたの rig（PC構成）を診断。
      <br class="hidden md:block" />
      実機ベンチマークに基づいた推奨で、迷いをなくす。
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        href="/match/"
        class="inline-block px-8 py-3 rounded-lg bg-[var(--color-accent)] text-[var(--color-bg)] font-semibold hover:bg-[var(--color-accent-hover)] transition"
      >
        診断を始める →
      </a>
      <a
        href="/blog/"
        class="inline-block px-8 py-3 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] transition"
      >
        記事一覧
      </a>
    </div>
    <p class="mt-6 text-xs text-[var(--color-text-muted)]">
      実機テスト · 提供記事ゼロ · 推奨は性能とコスパ基準
    </p>
  </section>

  <section class="py-4 md:py-8">
    <img
      src="/hero.png"
      alt="AI開発機・ゲーミング・ノートPC・Mac Studio・ワークステーション・ラップトップが並ぶイラスト"
      width="1672"
      height="941"
      loading="eager"
      decoding="async"
      class="w-full max-w-5xl mx-auto rounded-2xl shadow-sm"
    />
  </section>

  <section class="py-8">
    <h2 class="text-2xl font-bold mb-2">用途で選ぶ</h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-6">あなたの用途を選んでください</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-[var(--color-border)] border border-[var(--color-border)]">
      {sections.map((s, i) => (
        <a
          href={s.href}
          class="group block p-6 bg-[var(--color-bg)] hover:bg-[var(--color-surface)] transition"
        >
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-mono text-xs text-[var(--color-text-muted)] tabular-nums">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-xs text-[var(--color-text-muted)]">{s.title}</span>
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-[var(--color-accent)] transition">
            {s.headline}
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{s.description}</p>
        </a>
      ))}
    </div>
  </section>

  {featuredPost && (
    <section class="py-12 mt-8 border-t border-[var(--color-border)]">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-bold">注目の記事</h2>
        <a href="/blog/" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">
          すべての記事
        </a>
      </div>
      <a
        href={`/blog/${featuredPost.id.replace(/^ja\//, '')}/`}
        class="block p-6 md:p-8 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)] transition"
      >
        <div class="flex flex-wrap gap-2 text-xs text-[var(--color-text-muted)] mb-3">
          <span class="px-2 py-0.5 rounded bg-[var(--color-bg)]">
            {sectionLabels[featuredPost.data.section] ?? featuredPost.data.section}
          </span>
          <span class="px-2 py-0.5 rounded bg-[var(--color-bg)]">
            {categoryLabels[featuredPost.data.category] ?? featuredPost.data.category}
          </span>
          <time class="ml-auto self-center">{fmtDate(featuredPost.data.date)}</time>
        </div>
        <h3 class="text-2xl md:text-3xl font-bold mb-3 leading-tight">{featuredPost.data.title}</h3>
        <p class="text-[var(--color-text-muted)]">{featuredPost.data.description}</p>
      </a>
    </section>
  )}

  {latestPosts.length > 1 && (
    <section class="py-12 border-t border-[var(--color-border)]">
      <h2 class="text-2xl font-bold mb-6">最新記事</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {latestPosts.slice(featuredPost === latestPosts[0] ? 1 : 0).map((post) => {
          const slug = post.id.replace(/^ja\//, '');
          return (
            <li>
              <a
                href={`/blog/${slug}/`}
                class="block p-5 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)] transition h-full"
              >
                <div class="flex flex-wrap gap-2 text-xs text-[var(--color-text-muted)] mb-2">
                  <span class="px-2 py-0.5 rounded bg-[var(--color-bg)]">
                    {sectionLabels[post.data.section] ?? post.data.section}
                  </span>
                  <span class="px-2 py-0.5 rounded bg-[var(--color-bg)]">
                    {categoryLabels[post.data.category] ?? post.data.category}
                  </span>
                  <time class="ml-auto self-center">{fmtDate(post.data.date)}</time>
                </div>
                <h3 class="text-lg font-semibold mb-2">{post.data.title}</h3>
                <p class="text-sm text-[var(--color-text-muted)] line-clamp-2">{post.data.description}</p>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <section class="py-12 border-t border-[var(--color-border)]">
    <h2 class="text-2xl font-bold mb-2">mypcrig が約束する3点</h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-8">それ以上は約束しない。</p>
    <dl class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-6">
      <div class="border-l-2 border-[var(--color-accent)] pl-5">
        <dt class="text-base font-semibold mb-2">実機で測ってから書く</dt>
        <dd class="text-sm text-[var(--color-text-muted)] leading-relaxed">propel-lab の検証環境で実測。スペックシートだけでは見えない実用性能を反映する。</dd>
      </div>
      <div class="border-l-2 border-[var(--color-accent)] pl-5">
        <dt class="text-base font-semibold mb-2">用途から構成を決める</dt>
        <dd class="text-sm text-[var(--color-text-muted)] leading-relaxed">「ローカルLLMを動かしたい」「動画編集中心」など、用途から最適構成を3案で提示する。</dd>
      </div>
      <div class="border-l-2 border-[var(--color-accent)] pl-5">
        <dt class="text-base font-semibold mb-2">提供記事は受けない</dt>
        <dd class="text-sm text-[var(--color-text-muted)] leading-relaxed">アフィリリンクは含む。が、推奨ロジックは性能とコスパだけで決める。広告主の意向は入らない。</dd>
      </div>
    </dl>
  </section>
</BaseLayout>
