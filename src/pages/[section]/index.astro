---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const sections = [
    {
      slug: 'laptop',
      title: 'ノートPC',
      description: '学生・ビジネス・クリエイター向けノートPCの選び方とランキング',
    },
    {
      slug: 'gaming',
      title: 'ゲーミングPC',
      description: 'FPS / MMO / 配信に最適な構成。予算別ランキング',
    },
    {
      slug: 'ai-dev',
      title: 'AI開発向け',
      description: 'ローカルLLM / Claude Code / AI画像生成の実機ベンチマーク',
    },
    {
      slug: 'mac',
      title: 'Mac',
      description: 'Apple Silicon の選び方。M3 / M4 シリーズ徹底比較',
    },
    {
      slug: 'desktop',
      title: 'デスクトップ',
      description: 'BTO・自作の構成提案。拡張性と静音性のバランス',
    },
    {
      slug: 'parts',
      title: 'パーツ単体',
      description: 'GPU / CPU / メモリの単品レビューと比較',
    },
    {
      slug: 'column',
      title: 'コラム',
      description: '雑学・基礎知識。スペックの読み方を体系的に',
    },
  ];

  return sections.map((s) => ({
    params: { section: s.slug },
    props: { sectionMeta: s },
  }));
}

const { sectionMeta } = Astro.props;
const posts = (await getCollection('blog'))
  .filter((p) => p.data.section === sectionMeta.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels: Record<string, string> = {
  ranking: 'ランキング',
  review: 'レビュー',
  guide: 'ガイド',
  benchmark: 'ベンチマーク',
  comparison: '比較',
  column: 'コラム',
};

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
---

<BaseLayout
  title={`${sectionMeta.title} — mypcrig`}
  description={sectionMeta.description}
>
  <header class="py-8 mb-6 border-b border-[var(--color-border)]">
    <h1 class="text-3xl font-bold mb-2">{sectionMeta.title}</h1>
    <p class="text-[var(--color-text-muted)]">{sectionMeta.description}</p>
    <p class="text-sm text-[var(--color-text-muted)] mt-2">{posts.length} 記事</p>
  </header>

  {posts.length === 0 ? (
    <div class="py-12 text-center">
      <p class="text-[var(--color-text-muted)] mb-6">
        この section の記事は準備中です。
      </p>
      <a
        href="/match"
        class="inline-block px-6 py-2 rounded bg-[var(--color-accent)] text-[var(--color-bg)] font-semibold hover:bg-[var(--color-accent-hover)] transition"
      >
        診断で構成を提案する →
      </a>
    </div>
  ) : (
    <ul class="space-y-4">
      {posts.map((post) => {
        const slug = post.id.replace(/^ja\//, '');
        return (
          <li class="p-5 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)] transition">
            <a href={`/blog/${slug}/`} class="block">
              <div class="flex flex-wrap gap-2 text-xs text-[var(--color-text-muted)] mb-2">
                <span class="px-2 py-0.5 rounded bg-[var(--color-bg)]">
                  {categoryLabels[post.data.category] ?? post.data.category}
                </span>
                <time class="ml-auto self-center">{fmtDate(post.data.date)}</time>
              </div>
              <h2 class="text-lg font-semibold mb-1 text-[var(--color-text)]">{post.data.title}</h2>
              <p class="text-sm text-[var(--color-text-muted)]">{post.data.description}</p>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</BaseLayout>
