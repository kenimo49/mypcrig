---
import BaseLayout from './BaseLayout.astro';
import { categoryLabels, sectionLabels } from '../data/sections';

interface SummarySpec {
  label: string;
  value: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  category: string;
  section: string;
  tags: string[];
  canonical?: string;
  ogImage?: string;
  affiliateDisclosure?: boolean;
  score?: number;
  scoreLabel?: string;
  pros?: string[];
  cons?: string[];
  verdict?: string;
  summarySpecs?: SummarySpec[];
  priceYen?: number;
  purchaseUrl?: string;
  faq?: FaqItem[];
}

const {
  title,
  description,
  date,
  updated,
  category,
  section,
  tags,
  canonical,
  ogImage,
  affiliateDisclosure = true,
  score,
  scoreLabel,
  pros = [],
  cons = [],
  verdict,
  summarySpecs = [],
  priceYen,
  purchaseUrl,
  faq = [],
} = Astro.props;

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);

const fmtPrice = (yen?: number) =>
  yen ? `¥${yen.toLocaleString('ja-JP')}` : null;

const showSummaryCard =
  score !== undefined ||
  pros.length > 0 ||
  cons.length > 0 ||
  verdict ||
  summarySpecs.length > 0 ||
  priceYen !== undefined;

const siteUrl = 'https://mypcrig.com';
const pageUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbs = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href)
  : new URL('/og-default.png', siteUrl).href;

const breadcrumbItems = [
  { name: 'トップ', url: `${siteUrl}/` },
  {
    name: sectionLabels[section] ?? section,
    url: `${siteUrl}/${section}/`,
  },
  { name: title, url: pageUrl },
];

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: ogImageAbs,
  datePublished: date.toISOString(),
  ...(updated ? { dateModified: updated.toISOString() } : { dateModified: date.toISOString() }),
  author: {
    '@type': 'Person',
    name: 'ken imoto',
    url: 'https://kenimoto.dev/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'mypcrig',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const productJsonLd =
  category === 'review' && score !== undefined
    ? {
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: title,
        description,
        image: ogImageAbs,
        ...(priceYen
          ? {
              offers: {
                '@type': 'Offer',
                priceCurrency: 'JPY',
                price: priceYen,
                ...(purchaseUrl ? { url: purchaseUrl } : {}),
                availability: 'https://schema.org/InStock',
              },
            }
          : {}),
        review: {
          '@type': 'Review',
          reviewRating: {
            '@type': 'Rating',
            ratingValue: score,
            bestRating: 10,
            worstRating: 0,
          },
          author: {
            '@type': 'Person',
            name: 'ken imoto',
          },
          ...(verdict ? { reviewBody: verdict } : {}),
          ...(pros.length > 0 ? { positiveNotes: { '@type': 'ItemList', itemListElement: pros.map((p, i) => ({ '@type': 'ListItem', position: i + 1, name: p })) } } : {}),
          ...(cons.length > 0 ? { negativeNotes: { '@type': 'ItemList', itemListElement: cons.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c })) } } : {}),
        },
      }
    : null;

const faqJsonLd =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: f.answer,
          },
        })),
      }
    : null;

const jsonLd = [
  articleJsonLd,
  breadcrumbJsonLd,
  ...(productJsonLd ? [productJsonLd] : []),
  ...(faqJsonLd ? [faqJsonLd] : []),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={jsonLd}
  ogType="article"
  articleMeta={{
    publishedTime: date.toISOString(),
    modifiedTime: (updated ?? date).toISOString(),
    author: 'ken imoto',
    section: sectionLabels[section] ?? section,
    tags,
  }}
>
  <article class="max-w-4xl mx-auto py-8">
    <header class="mb-8 pb-6 border-b border-[var(--color-border)]">
      <nav class="text-xs text-[var(--color-text-muted)] mb-4">
        <a href="/" class="hover:text-[var(--color-accent)]">トップ</a>
        <span class="mx-2 opacity-50">›</span>
        <a href={`/${section}/`} class="hover:text-[var(--color-accent)]">
          {sectionLabels[section] ?? section}
        </a>
        {section !== 'column' && (
          <>
            <span class="mx-2 opacity-50">›</span>
            <span>{categoryLabels[category] ?? category}</span>
          </>
        )}
      </nav>

      <div class="flex flex-wrap gap-2 text-xs text-[var(--color-text-muted)] mb-3">
        <a
          href={`/${section}/`}
          class="px-2 py-1 rounded bg-[var(--color-surface)] hover:text-[var(--color-accent)]"
        >
          {sectionLabels[section] ?? section}
        </a>
        <span class="px-2 py-1 rounded bg-[var(--color-surface)]">
          {categoryLabels[category] ?? category}
        </span>
        <time class="ml-auto self-center">{fmtDate(date)}</time>
        {updated && (
          <span class="self-center">更新 {fmtDate(updated)}</span>
        )}
      </div>

      <h1 class="text-3xl md:text-4xl font-bold leading-tight">{title}</h1>
      {description && (
        <p class="mt-4 text-[var(--color-text-muted)]">{description}</p>
      )}
      {tags && tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mt-4 text-xs">
          {tags.map((tag) => (
            <li class="px-2 py-1 rounded text-[var(--color-text-muted)] border border-[var(--color-border)]">
              #{tag}
            </li>
          ))}
        </ul>
      )}
    </header>

    {affiliateDisclosure && (
      <p class="text-xs text-[var(--color-text-muted)] mb-8 p-3 rounded bg-[var(--color-surface)] border border-[var(--color-border)]">
        本記事は Amazon.co.jp および各販売店のアフィリエイトリンクを含む場合があります。推奨は性能・コスパ・実機ベンチマーク基準で編集判断しており、提供記事は受け付けていません。詳細は <a href="/privacy/" class="text-[var(--color-accent)] hover:underline">プライバシーポリシー</a> をご覧ください。
      </p>
    )}

    {showSummaryCard && (
      <aside class="mb-10 p-6 bg-[var(--color-surface)] border-l-2 border-[var(--color-accent)]">
        <div class="flex flex-wrap gap-6 items-start">
          {score !== undefined && (
            <div class="flex-shrink-0">
              <div class="flex items-baseline gap-2">
                <span class="text-5xl font-bold text-[var(--color-accent)]">{score.toFixed(1)}</span>
                <span class="text-sm text-[var(--color-text-muted)]">/ 10</span>
              </div>
              {scoreLabel && (
                <p class="text-sm text-[var(--color-text-muted)] mt-1">{scoreLabel}</p>
              )}
            </div>
          )}

          <div class="flex-1 min-w-0 space-y-3">
            {summarySpecs.length > 0 && (
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1 text-sm">
                {summarySpecs.map((s) => (
                  <div class="flex justify-between gap-2 py-1 border-b border-[var(--color-border)]/50">
                    <dt class="text-[var(--color-text-muted)]">{s.label}</dt>
                    <dd class="font-medium text-right">{s.value}</dd>
                  </div>
                ))}
              </dl>
            )}

            {priceYen !== undefined && (
              <div class="flex items-center gap-3">
                <span class="text-2xl font-bold">{fmtPrice(priceYen)}</span>
                {purchaseUrl && (
                  <a
                    href={purchaseUrl}
                    rel="nofollow sponsored noopener"
                    class="px-4 py-2 rounded bg-[var(--color-accent)] text-[var(--color-bg)] font-semibold text-sm hover:bg-[var(--color-accent-hover)] transition"
                  >
                    最新価格を見る
                  </a>
                )}
              </div>
            )}
          </div>
        </div>

        {(pros.length > 0 || cons.length > 0) && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-6 pt-6 border-t border-[var(--color-border)]">
            {pros.length > 0 && (
              <div>
                <h3 class="text-xs font-semibold tracking-wider uppercase text-[var(--color-text-muted)] mb-3">良い点</h3>
                <ul class="space-y-1.5 text-sm">
                  {pros.map((p) => (
                    <li class="flex gap-2">
                      <span class="text-[var(--color-accent)] flex-shrink-0 font-bold">＋</span>
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {cons.length > 0 && (
              <div>
                <h3 class="text-xs font-semibold tracking-wider uppercase text-[var(--color-text-muted)] mb-3">気になる点</h3>
                <ul class="space-y-1.5 text-sm">
                  {cons.map((c) => (
                    <li class="flex gap-2">
                      <span class="text-[var(--color-text-muted)] flex-shrink-0 font-bold">−</span>
                      <span>{c}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        {verdict && (
          <div class="mt-6 pt-6 border-t border-[var(--color-border)]">
            <h3 class="text-xs font-semibold tracking-wider uppercase text-[var(--color-text-muted)] mb-2">結論</h3>
            <p class="text-sm leading-relaxed">{verdict}</p>
          </div>
        )}
      </aside>
    )}

    <div class="prose max-w-none
      prose-headings:text-[var(--color-text)]
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-[var(--color-border)]
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-[var(--color-text)] prose-p:leading-7
      prose-a:text-[var(--color-accent)] hover:prose-a:text-[var(--color-accent-hover)]
      prose-strong:text-[var(--color-text)]
      prose-code:text-[var(--color-accent)] prose-code:bg-[var(--color-surface)] prose-code:px-1 prose-code:rounded prose-code:before:content-[''] prose-code:after:content-['']
      prose-pre:bg-[var(--color-surface)] prose-pre:border prose-pre:border-[var(--color-border)]
      prose-img:rounded-lg
      prose-ul:text-[var(--color-text)]
      prose-ol:text-[var(--color-text)]
      prose-table:text-sm
      prose-th:text-[var(--color-text)] prose-th:bg-[var(--color-surface)]
      prose-td:border-[var(--color-border)]
      prose-blockquote:border-l-[var(--color-accent)] prose-blockquote:text-[var(--color-text-muted)]">
      <slot />
    </div>

    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <div class="flex flex-wrap gap-4 justify-between items-center text-sm">
        <a href={`/${section}/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)]">
          ← {sectionLabels[section] ?? section} の記事一覧
        </a>
        <a href="/match/" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">
          PC構成を診断する →
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
